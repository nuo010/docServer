<?xml version="1.0" encoding="UTF-8"?>
<!--
  仅用于绕过本机访问 repo.maven.apache.org 出现 403 等问题：
  将 Maven Central 请求镜像到阿里云（与官方 Central 同步的 central 仓库）。
  使用方式：在项目根目录执行 mvn -s .mvn/settings.xml ...；
  或已通过 .mvn/maven.config 自动指定（见该文件）。
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 https://maven.apache.org/xsd/settings-1.2.0.xsd">

    <mirrors>
        <mirror>
            <id>aliyun-central</id>
            <mirrorOf>central</mirrorOf>
            <name>Aliyun mirror of Maven Central</name>
            <url>https://maven.aliyun.com/repository/central</url>
        </mirror>
    </mirrors>
</settings>
